# 2278 - i++
# Read a digit '0'-'9' and output the next digit (mod 10)
# '0' (48) -> '1' (49)
# '9' (57) -> '0' (48)

# Create lookup table in memory
[48]<49   # '0' -> '1'
[49]<50   # '1' -> '2'
[50]<51   # '2' -> '3'
[51]<52   # '3' -> '4'
[52]<53   # '4' -> '5'
[53]<54   # '5' -> '6'
[54]<55   # '6' -> '7'
[55]<56   # '7' -> '8'
[56]<57   # '8' -> '9'
[57]<48   # '9' -> '0'

# Read input
A<I

# Lookup result
B<[A]

# Output
O<B

# Halt
Z<1
